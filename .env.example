# Telegram Bot Token (lấy từ @BotFather)
TELEGRAM_BOT_TOKEN=

# Google Gemini API Key (lấy từ aistudio.google.com)
GEMINI_API_KEY=

# Firebase Project ID
FIREBASE_PROJECT_ID=

# Firebase Private Key (Service Account)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Firebase Client Email (Service Account)
FIREBASE_CLIENT_EMAIL=

# Webhook URL khi deploy lên Railway (ví dụ: https://your-app.railway.app)
WEBHOOK_URL=

# Port server (Railway tự set, để mặc định 3000 khi dev local)
PORT=3000

# Telegram ID của chủ bot (lấy từ @userinfobot)
OWNER_TELEGRAM_ID=
